{
  "name": "no.runely.jslogic",
  "version": "1.3.2",
  "main": "app.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@tsconfig/node24": "^24.0.4",
    "@types/homey": "npm:homey-apps-sdk-v3-types@0.3.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "moment-timezone": "^0.6.1"
  },
  "scripts": {
    "refresh": "rm -rf node_modules/ && rm package-lock.json && npm i",
    "build": "tsc",
    "lint": "npx @biomejs/biome check",
    "build-tests": "tsc -p tsconfig_tests.json",
    "test": "npm run lint && npm run build-tests && env TZ=UTC jest",
    "fix": "npx @biomejs/biome check --write",
    "homey-run": "homey app run --clean --remote",
    "homey-install": "npm run test && homey app install",
    "homey-publish": "npm run test && homey app publish"
  },
  "repository": {
    "url": "https://github.com/runely/jslogic-homey"
  },
  "license": "GPL-3.0-or-later",
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/.homeybuild/"
    ],
    "testMatch": [
      "<rootDir>/.build/tests/**/*test.[jt]s?(x)",
      "<rootDir>/.build/?(*.)+.(spec|test).[jt]s?(x)"
    ]
  }
}
